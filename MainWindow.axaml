<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="using:GestionClientsAvalonia"
        mc:Ignorable="d"
        d:DesignWidth="800"
        d:DesignHeight="450"
        x:Class="GestionClientsAvalonia.MainWindow"
        Title="Gestion Clients"
        MinWidth="650"
        MinHeight="600">

    <Grid
        Margin="20"
        RowSpacing="10">

        <Grid.RowDefinitions>
            <!-- Formulaire et boutons -->
            <RowDefinition
                Height="Auto"
                MaxHeight="400" />

            <!-- Barre de recherche -->
            <RowDefinition
                Height="Auto" />

            <!-- Liste des clients -->
            <RowDefinition
                Height="*"
                MinHeight="150" />
        </Grid.RowDefinitions>

        <!-- Zone supérieure défilable -->
        <ScrollViewer
            Grid.Row="0"
            VerticalScrollBarVisibility="Auto"
            HorizontalScrollBarVisibility="Disabled">

            <StackPanel
                Spacing="10"
                Margin="0,0,8,0">

                <TextBlock
                    Text="Gestion Clients"
                    FontSize="28" />

                <TextBox
                    x:Name="NomTextBox"
                    PlaceholderText="Nom du client" />

                <TextBox
                    x:Name="EmailTextBox"
                    PlaceholderText="Email du client" />

                <!-- Actions sur les clients -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="10">

                    <Button
                        Content="Nouveau / Vider"
                        Click="NewClient_Click" />

                    <Button
                        Content="Ajouter"
                        Click="AddClient_Click" />

                    <Button
                        x:Name="UpdateButton"
                        Content="Modifier"
                        Click="UpdateClient_Click"
                        IsEnabled="False" />

                    <Button
                        x:Name="DeleteButton"
                        Content="Supprimer"
                        Click="DeleteClient_Click"
                        IsEnabled="False" />

                </StackPanel>

                <!-- Actions sur les fichiers CSV -->
                <StackPanel
                    Orientation="Horizontal"
                    Spacing="10">

                    <Button
                        Content="Exporter CSV"
                        Click="ExportClients_Click" />

                    <Button
                        Content="Importer CSV"
                        Click="ImportClients_Click" />

                </StackPanel>

                <TextBlock
                    x:Name="MessageTextBlock" />

            </StackPanel>
        </ScrollViewer>

        <!-- Recherche toujours visible -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10">

            <TextBox
                x:Name="SearchTextBox"
                Grid.Column="0"
                PlaceholderText="Rechercher par nom ou email" />

            <Button
                Grid.Column="1"
                Content="Rechercher"
                Click="SearchClient_Click" />
        </Grid>

        <!-- Compteur, en-têtes et liste -->
        <Grid
            Grid.Row="2"
            RowDefinitions="Auto,Auto,*"
            RowSpacing="5">

            <TextBlock
                x:Name="ClientCountTextBlock"
                Grid.Row="0"
                Text="0 client affiché"
                FontWeight="SemiBold"
                Margin="0,5,0,5" />

            <Grid
                Grid.Row="1"
                ColumnDefinitions="60,180,*"
                ColumnSpacing="15"
                Margin="8,5,8,5">

                <TextBlock
                    Grid.Column="0"
                    Text="Id"
                    FontWeight="Bold" />

                <TextBlock
                    Grid.Column="1"
                    Text="Nom"
                    FontWeight="Bold" />

                <TextBlock
                    Grid.Column="2"
                    Text="Email"
                    FontWeight="Bold" />

            </Grid>

            <ListBox
                x:Name="ClientListBox"
                Grid.Row="2"
                SelectionChanged="ClientListBox_SelectionChanged">

                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter
                            Property="HorizontalContentAlignment"
                            Value="Stretch" />
                    </Style>
                </ListBox.Styles>

                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="local:Client">

                        <Grid
                            ColumnDefinitions="60,180,*"
                            ColumnSpacing="15">

                            <TextBlock
                                Grid.Column="0"
                                Text="{Binding Id}" />

                            <TextBlock
                                Grid.Column="1"
                                Text="{Binding Nom}" />

                            <TextBlock
                                Grid.Column="2"
                                Text="{Binding Email}" />

                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>
        </Grid>

    </Grid>
</Window>